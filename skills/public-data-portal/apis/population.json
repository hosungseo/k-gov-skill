{
  "id": "mois-resident-population",
  "title": "행정안전부 주민등록 인구현황",
  "provider": "행정안전부",
  "auth": "user-key-required",
  "env": "DATA_GO_KR_SERVICE_KEY",
  "portalSearch": "https://www.data.go.kr/tcs/dss/selectDataSetList.do?keyword=주민등록%20인구",
  "endpoint": "https://apis.data.go.kr/1741000/admmPpltnStatsService/getAdmmPpltnStats",
  "method": "GET",
  "defaultParams": {
    "serviceKey": "${DATA_GO_KR_SERVICE_KEY}",
    "pageNo": "1",
    "numOfRows": "10",
    "type": "json"
  },
  "outputs": ["행정구역", "인구수", "세대수", "기준시점"],
  "fallback": "serviceKey가 없으면 활용신청 경로와 파라미터 예시를 안내한다.",
  "safety": ["집계값 중심으로 사용", "기준일 표시", "대량 호출 전 이용조건 확인"]
}
